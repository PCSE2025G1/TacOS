//-----------------------------------------------------------------------------
// グローバル変数
//-----------------------------------------------------------------------------
public int currentPlayMode = MODE_NORMAL;
public int idx = 0;
public int totalSongs = 0;
public boolean is_normal = true;
public boolean is_loop = false;
public boolean is_repeat = false;
public boolean is_shuffle = false;


int[] originalOrder;      // 元の曲順を保持
int[] shuffleOrder;       // シャッフル順序を保持
int shuffleIndex = 0;     // シャッフル再生での現在位置
boolean[] playedInShuffle; // シャッフルで再生済みかどうか
int shufflePlayedCount = 0; // シャッフルで再生済み曲数

//-----------------------------------------------------------------------------
// 内部関数（非公開）
//-----------------------------------------------------------------------------

// シャッフル順序生成
void generateShuffleOrder() {
    if (totalSongs <= 1) return;
    
    for (int i = 0; i < totalSongs; i = i + 1) {
        shuffleOrder[i] = originalOrder[i];
        playedInShuffle[i] = false;
    }
    
    // Fisher-Yates シャッフル
    for (int i = totalSongs - 1; i > 0; i = i - 1) {
        int j = rand() % (i + 1);
        int temp = shuffleOrder[i];
        shuffleOrder[i] = shuffleOrder[j];
        shuffleOrder[j] = temp;
    }
    
    shuffleIndex = 0;
    shufflePlayedCount = 0;
}

// 曲番号から配列インデックスを取得
int getSongIndex(int songNumber) {
    for (int i = 0; i < totalSongs; i = i + 1) {
        if (originalOrder[i] == songNumber) {
            return i;
        }
    }
    return 0;
}

// 現在の曲番号を取得
int getCurrentSongNumber() {
    if (currentPlayMode == MODE_SHUFFLE) {
        if (shuffleIndex >= 0 && shuffleIndex < totalSongs) {
            return shuffleOrder[shuffleIndex];
        }
    }
    return idx + 1;
}

// 再生モード文字列を取得
char[] getPlayModeString() {
    if (currentPlayMode == MODE_NORMAL) {
        return "Normal";
    } else if (currentPlayMode == MODE_LOOP) {
        return "Loop";
    } else if (currentPlayMode == MODE_REPEAT) {
        return "Repeat";
    } else if (currentPlayMode == MODE_SHUFFLE) {
        return "Shuffle";
    }
    return "Unknown";
}

//-----------------------------------------------------------------------------
// モード設定関数群
//-----------------------------------------------------------------------------

// ノーマルモード設定
public void normal() {
    dbgPutStr("Normal");
    currentPlayMode = MODE_NORMAL;
    
    // フラグ設定
    is_normal = true;
    is_loop = false;
    is_repeat = false;
    is_shuffle = false;
}

// ループモード設定
public void loop() {
    dbgPutStr("Loop");
    currentPlayMode = MODE_LOOP;
    
    // フラグ設定
    is_normal = false;
    is_loop = true;
    is_repeat = false;
    is_shuffle = false;
}

// リピートモード設定
public void repeat() {
    dbgPutStr("Repeat");
    currentPlayMode = MODE_REPEAT;

    // フラグ設定
    is_normal = false;
    is_loop = false;
    is_repeat = true;
    is_shuffle = false;
}

// シャッフルモード設定
public void shuffle() {
    dbgPutStr("Shuffle");
    currentPlayMode = MODE_SHUFFLE;
    
    // フラグ設定
    is_normal = false;
    is_loop = false;
    is_repeat = false;
    is_shuffle = true;
}


// 履歴取得（プレースホルダー）
public void get_history() {
  // 履歴機能の実装はここに追加
}


//-----------------------------------------------------------------------------
// プレイリスト管理関数
//-----------------------------------------------------------------------------
// 曲の合計数
int getTotalSongs() {
    int count = 0;
    for (int i = 1; i <= 5; i = i + 1) {
        if (mp3FilesGetName(i) != null) {
            count = count + 1;
        }
    }
    return count;
}

// プレイリスト初期化(ノーマル順、シャッフル順の初期化)
public void initPlaylist() {
    totalSongs = getTotalSongs();
    if (totalSongs == 0) return;
    
    originalOrder = malloc(sizeof(int) * totalSongs);
    shuffleOrder = malloc(sizeof(int) * totalSongs);
    playedInShuffle = malloc(sizeof(boolean) * totalSongs);
    
    int index = 0;
    for (int i = 1; i <= 5; i = i + 1) {
        if (mp3FilesGetName(i) != null) {
            originalOrder[index] = i;
            shuffleOrder[index] = i;
            playedInShuffle[index] = false;
            index = index + 1;
        }
    }
}


//-----------------------------------------------------------------------------
// 再生制御関数
//-----------------------------------------------------------------------------

public void next() {
    if (totalSongs == 0) return;
    if (currentPlayMode == MODE_REPEAT) {
        return;
    }
    boolean wasPlaying = ((playstatus == 1)||(playstatus == -1));
    if (wasPlaying) {
        // stopPlay();
        stop(false); // 再生停止
    }
    
    // switch文をif-else文に変更
    if (currentPlayMode == MODE_NORMAL) {
        idx = idx + 1;
        if (idx >= totalSongs) {
            idx = totalSongs - 1;
            return;
        }
    } else if (currentPlayMode == MODE_LOOP) {
        // 全曲を順に再生し、最後まで行ったら最初に戻る
        idx = (idx + 1) % totalSongs;
    } else if (currentPlayMode == MODE_SHUFFLE) {
        shuffleIndex = shuffleIndex + 1;
        if (shuffleIndex >= totalSongs) {
            generateShuffleOrder();
        }
        idx = getSongIndex(shuffleOrder[shuffleIndex]);
    }
    
    // startPlay(); // 再生を開始
    play(mp3FilesGetPath(idx+1)); // 再生開始
}

public void previous() {
    if (totalSongs == 0) return;
    if (currentPlayMode == MODE_REPEAT) {
        return;
    }
    // boolean wasPlaying = (playstatus == 1);
    boolean wasPlaying = ((playstatus == 1)|| (playstatus == -1));
    if (wasPlaying) {
        // stopPlay();
        stop(false); // 再生停止
    }
    
    // switch文をif-else文に変更
    if (currentPlayMode == MODE_NORMAL) {
        idx = idx - 1;
        if (idx < 0) {
            idx = 0;
            return;
        }
    } else if (currentPlayMode == MODE_LOOP) {
        idx = (idx - 1 + totalSongs) % totalSongs;
    } else if (currentPlayMode == MODE_SHUFFLE) {
        shuffleIndex = shuffleIndex - 1;
        if (shuffleIndex < 0) {
            generateShuffleOrder();
            shuffleIndex = totalSongs - 1;
        }
        idx = getSongIndex(shuffleOrder[shuffleIndex]);
    }
    
    // startPlay(); // 再生を開始
    play(mp3FilesGetPath(idx+1)); // 再生開始
}



public void onSongEnd() {
    if (currentPlayMode == MODE_NORMAL) {
      dbgPutStr("Normal End");
      stop(false);
        // if (idx + 1 < totalSongs) {
        //     next();
        // } else {
        //     // stopPlay();
        //   stop(); // 再生停止
        // }
    } else if (currentPlayMode == MODE_LOOP) {
      dbgPutStr("Loop End");
      next();
    } else if (currentPlayMode == MODE_REPEAT) {
      dbgPutStr("Repeat End");
      play(mp3FilesGetPath(idx+1)); // 再生開始
    } else if (currentPlayMode == MODE_SHUFFLE) {
      dbgPutStr("Shuffle End");
      next();
    }
}


//================================================================================
// 2: 再生処理
// ===============================================================================
//-----------------------------------------------------------------------------
// screen2: 再生画面
//-----------------------------------------------------------------------------
public void screen2() {
    cls();
    // タイトル
    locateXY(0, 0);
    putStr("Play Mode");
    locateXY(10, 0);    // 右側に曲番号を表示
    putDec(idx + 1, 1); // 現在の曲番号（1から始まる）
    putStr("/");
    putDec(getTotalSongs(), 1); // 総曲数
    
    // N/L/R/S モード表示(全部で16文字)
    locateXY(8,1);
    if (is_normal) putStr("N");
    else putStr("-");
    putStr("/");    
    if (is_loop) putCh(chr(0x83));//putStr("L");
    else putStr("-");
    putStr("/");
    if (is_repeat) putCh(chr(0x82));//putStr("R");
    else putStr("-");
    putStr("/");
    if (is_shuffle) putCh(chr(0x81));//putStr("S");
    else putStr("-");
  

    // // お気に入り表示
    // if (queue[idx].fav) {
    //   locateXY(0, 1);    // ハートを表示する位置（例：画面右上）
    //   putCh(chr(0x86));  // お気に入り ❤️
    // }; // 現在の曲のお気に入り状態


    // ファイル名取得（idx + 1）を使って screen1 と一致
    int songNum = idx + 1; 
    char[] fname = mp3FilesGetName(songNum); 
    if (fname != null) {
        locateXY(2, 3);
        putStr(fname);
    }
    
    // パス表示（あれば）
    char[] path = mp3FilesGetPath(idx + 1);
    if (path != null) {
        locateXY(2, 4);
        putStr(path);
    } else {
        locateXY(2, 4);
        putStr("N/A");
    }
    
    // 再生状態
    locateXY(6, 5);
    // 再生中
    // if (playstatus == 1) {
    if (isPaused) {
        // putStr("||");
        putCh(chr(0x7f)); // 再生中のアイコン
    // 停止中
    } else {
        // putStr(">|");
        putCh(chr(0x80)); //停止中のアイコン
    }
    
    // 前/次
    locateXY(2, 5);
    // putStr("<");
    putCh(chr(0x85));
    locateXY(10, 5);
    // putStr(">");
    putCh(chr(0x84));
    // 操作説明
    // locateXY(0, 7);
    // putStr("1:戻る 2/4:↑↓ 3:mode 4:next 5:決定 6:prev");
}

