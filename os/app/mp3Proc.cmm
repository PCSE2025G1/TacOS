// 再生状態管理
int currentFd = -1;                         // 現在のファイルディスクリプタ
char[] currentPath = null;                  // 現在再生中のファイルパス

//-----------------------------------------------------------------------------
// クライアントプロセスが呼び出す
//-----------------------------------------------------------------------------
public boolean Upscreen = false;
public boolean wasStoppedByUser = false;

void updatePlaybackTime() {
  // SCI_DECODE_TIME は 0x04
  playbackSeconds = spiReadMp3Reg(0x04);
}

void debugPlaybackTime() {
  updatePlaybackTime();  // 現在の秒数を取得
  int total = estimatedTotalSeconds;
  int current = playbackSeconds;
  int steps = 10;
  int filled;
  if (total > 0) {
    filled = (current * steps) / total;
  } else {
    filled = 0;
  }
  char[] bar = malloc(12);
  for (int i = 0; i < steps; i = i + 1) {
    if (i < filled) {
      bar[i] = '#';
    } else {
      bar[i] = '-';
    }
  }
  bar[10] = '\0';
  printF("----------------------------\n");
  printF("再生時間: %d / %d 秒\n", current, total);
  printF("進行度  : [%s] %d/10\n", bar, filled);
  printF("----------------------------\n");
  free(bar);
}



// 音楽再生停止
public void stop(boolean user) {
  syncFlag = true;                          // データ転送プロセスをコマンド待にする
  debugPlaybackTime();                     // 再生時間の確認
  sndrec(link, STOP, 0, 0, 0);             // 同期要求メッセージ
  wasStoppedByUser = user;                 // ユーザーによる停止
  playstatus = 0;
}

// 音楽再生
public boolean play(char[] path) {
  syncFlag = true;                          // データ転送プロセスをコマンド待にする
  // isPaused = false;
  int r = sndrec(link, START,
                  _AtoI(path), 0, 0);       // 再生開始メッセージ
  wasStoppedByUser = false;                 // ユーザーによる停止
  playstatus = 1;
  return r==OK;                             // 成功なら true を返す
}

// 一時停止
public void mp3pause() {
  int r = sndrec(link, PAUSE, 0, 0, 0);
  if (r != OK) {
    dbgPutStr("Pause IPC failed\n");
  }
}

// 再開
public void mp3resume() {
  int r = sndrec(link, RESUME, 0, 0, 0);
  if (r != OK) {
    dbgPutStr("Resume IPC failed\n");
  }
}

//-----------------------------------------------------------------------------
// 音楽データ転送用のプロセス
//-----------------------------------------------------------------------------
// MP3 データ用のバッファ
char[] buf = array(BUFSIZ);

void calculateEstimatedDuration(char[] path) {
  Stat s;
  if (stat(path, s) < 0) {
    estimatedTotalSeconds = 0;
    return;
  }
  int h = s.lenH;  // 上位
  int l = s.lenL;  // 下位
  int kb = h * 64 + (l >> 10);
  int audata = spiReadMp3Reg(0x05);
  int sampleRate = (audata >> 1) & 0x7FFF;
  if (sampleRate == 0) sampleRate = 44100;
  int estimatedBitrateKBps = 16;
  estimatedTotalSeconds = kb / estimatedBitrateKBps;
}

// 音楽データをデコーダに送る
void trans(char[] path) {
  int fd = open(path, READ_MODE);
  if (fd < 0) {
    send(link, ERR);
    return;
  }
  send(link, OK);

  calculateEstimatedDuration(path);  // 再生前に再生時間見積もり

  int len;
  while (true) {
    if (syncFlag) break;

    // 🔁 pause中は read すらしない
    while (isPaused) {
      if (syncFlag) break;
      dbgPutStr("Paused...\n");
      sleep(100);
    }

    if (syncFlag) break;

    len = read(fd, buf, BUFSIZ);
    if (len <= 0) break;

    if (syncFlag) break;

    spiWriteMp3Dat(buf, len);
    updatePlaybackTime();

    // if (speed_delay > 0) sleep(speed_delay);  // 再生速度制御
  }
  // while ((len = read(fd, buf, BUFSIZ)) > 0) {
  //   // 停止された場合は抜ける
  //   if (syncFlag) break;

  //   // 一時停止処理
  //   while (isPaused) {
  //     if (syncFlag) break;  // pause中でもstopされたら抜ける
  //     dbgPutStr("Paused...\n");
  //     sleep(100);
  //   }

  //   if (syncFlag) break;

  //   spiWriteMp3Dat(buf, len);
  //   updatePlaybackTime();
  // }

  spiFlushMp3();
  close(fd);
  playstatus = -1;
}

