#include "settingsMng.hmm"
#include "spi.hmm"

/*
 * settingsMng.cmm : 音量調整と電源制御
 * 2025.06.27 : 初版
 */

int volume = 0x2020; // 初期音量（16dB減衰）

//-----------------------------------------------------------------------------
// 音量を上げる（音を大きく）
//-----------------------------------------------------------------------------
public void up_volume(){
    if (volume > 0x0000){
        volume = volume - 0x1010;     // 両チャンネルを1段階ずつ上げる
        spiWriteMp3Reg(0x0b, volume); // 音量設定レジスタに書き込み
    }
}

//-----------------------------------------------------------------------------
// 音量を下げる（音を小さく）
//-----------------------------------------------------------------------------
public void down_volume(){
    if (volume < 0xfeff){
        volume = volume + 0x1010; // 両チャンネルを1段階ずつ下げる
        spiWriteMp3Reg(0x0b, volume);
    }
}

//-----------------------------------------------------------------------------
// 電源オフ処理（MP3デコーダ停止など必要であれば追加）
//-----------------------------------------------------------------------------
public void power_off(){
    // 必要ならここでMP3停止や省電力モードへの移行などを行う
    // 現段階では空処理（メッセージ表示は main 側が担当）
}
