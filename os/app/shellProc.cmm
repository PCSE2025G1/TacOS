//-----------------------------------------------------------------------------
// スイッチの読み取り
//-----------------------------------------------------------------------------
// 押しボタンスイッチのビット
#define SW1 0x20
#define SW2 0x10
#define SW3 0x08
#define SW4 0x04
#define SW5 0x02
#define SW6 0x01
#define SWS 0x3f                                    // スイッチのビット全部

int sw0 = 0x00;                                     // 前回の状態(デバウンス前)
int sw1 = 0x00;                                     // 前回の状態(デバウンス後)

int readSw() {
  int sw = ~in(0x18) & SWS;                         // スイッチを読み正論理に変換
  int swd = sw & sw0;                               // デバウンス
  int sw2 = (sw1 ^ swd) & swd;                      // 今回，新たに押されたSW
  sw0 = sw;
  sw1 = swd;
  return sw2;
}

int swToNum(int sw) {
  int num = -1;
  if ((sw & SW6)!=0) {                              // 6 番のスイッチが押された
    num = 6;
  } else if ((sw & SW5)!=0) {                       // 5 番のスイッチが押された
    num = 5;
  } else if ((sw & SW4)!=0) {                       // 4 番のスイッチが押された
    num = 4;
  } else if ((sw & SW3)!=0) {                       // 3 番のスイッチが押された
    num = 3;
  } else if ((sw & SW2)!=0) {                       // 2 番のスイッチが押された
    num = 2;
  } else if ((sw & SW1)!=0) {                       // 1 番のスイッチが押された
    num = 1;
  }
  return num;
}
      

song[] queue;  // 再生キュー

void initQueue() {
  queue = malloc(sizeof(song) * 1);  // 構造体5つ分のメモリを確保

  for (int i = 0; i < 5; i = i + 1) {
    char[] name = mp3FilesGetName(i + 1);
    char[] path = mp3FilesGetPath(i + 1);

    if (name != null && path != null) {
      song s;
      s.index  = i;
      s.name   = name;
      s.fav    = false;
      s.artist = "unknown";
      s.path   = path;
      queue[i] = s;
    } else {
      song s;
      s.index = -1;
      queue[i] = s;
    }
  }
}

//-----------------------------------------------------------------------------
// 画面管理
//-----------------------------------------------------------------------------
int currentScreen = 0;                              // 現在の画面 (0:home, 1:screen1, 2:screen2, 3:screen3)
int homeSelection = 0;                              // ホーム画面での選択項目 (0:screen1, 1:screen2, 2:screen3)

//-----------------------------------------------------------------------------
// 共通のカーソル表示関数
//-----------------------------------------------------------------------------
// 指定した範囲の行のカーソルを更新する
// startRow: カーソル表示開始行
// itemCount: 選択肢の数
// selectedIndex: 現在選択されている項目のインデックス（0から開始）
void updateCursor(int startRow, int itemCount, int selectedIndex) {
  // 全ての行のカーソルをクリア
  for (int i = 0; i < itemCount; i = i + 1) {
    locateXY(0, startRow + i);
    putStr(" ");
  }
  
  // 現在の選択位置にカーソルを表示
  locateXY(0, startRow + selectedIndex);
  putStr(">");
}


//-----------------------------------------------------------------------------
// 共通のナビゲーション処理関数
//-----------------------------------------------------------------------------
// 上下移動処理を行い、選択項目が変更されたかどうかを返す
// currentSelection: 現在の選択項目のポインタ
// maxItems: 最大選択項目数
// buttonNum: 押されたボタン番号
// 戻り値: 選択項目が変更された場合1、変更されなかった場合0
int handleNavigationValue(int currentSelection, int maxItems, int buttonNum) {
  if (buttonNum == 2 && currentSelection > 0) {
    return currentSelection - 1;
  } else if (buttonNum == 4 && currentSelection < maxItems - 1) {
    return currentSelection + 1;
  }
  return currentSelection;
}

//-----------------------------------------------------------------------------
// 修正されたhomeScreen関数
//-----------------------------------------------------------------------------
void homeScreen() {
  cls();
  locateXY(0, 0);
  putStr("Home");
  
  // 選択肢の表示（カーソルを付けずに表示）
  locateXY(0, 2);
  putStr(" Screen1");
  locateXY(0, 3);
  putStr(" Screen2");
  locateXY(0, 4);
  putStr(" Screen3");
  
  // 操作説明
  locateXY(0, 6);
  putStr("2/4:Select 6:Enter");
  
  // 初期カーソル位置を設定
  updateCursor(2, 3, homeSelection); // 2行目から開始、3つの選択肢、現在の選択
}

//-----------------------------------------------------------------------------
// 画面1
//-----------------------------------------------------------------------------
void screen1() {
  dbgPutStr("demoScreen1\n"); // デバッグ出力
  cls();                                            // LCDをクリアする
  dbgPutStr("Cleared LCD\n"); // デバッグ出力
  locateXY(0,0);
  putStr("MP3 Player demo");
  for (int i=1; i<=5; i=i+1) {                      // スイッチ1〜5に付いて
    locateXY(2,i+1);
    putCh(chr(ord('0')+i));                         // スイッチの番号
    putStr(":");
    char[] fname = mp3FilesGetName(i);              // 対応するファイル名
    if (fname!=null) putStr(fname);
  }
  locateXY(2,7);
  putStr("6:stop");                                 // 6番のスイッチ

    // 画面切り替え用の表示
  locateXY(0,8);
  putStr("Press 1 for Settings");
}

void asta(int y) {
  screen1();
  locateXY(0, y+1);
  putCh('*');
}


//-----------------------------------------------------------------------------
// 画面表示 2: 設定画面
//-----------------------------------------------------------------------------
//-----------------------------------------------------------------------------
// グローバル変数：状態を保持
//-----------------------------------------------------------------------------
int mode = 0;            // 動作状態(0:選択中, 1:設定中)
int m_select = 0;        // 設定状態(0:音量, 1:電源)
int m_volume = 1;        // 音量(0~10)
int temp_volume = 1;     // 選択中の音量(決定ボタンで確定)
int powerIndex = 0;      // 電源状態(0:ON, 1:OFF)
int temp_powerIndex = 0; // 選択中の電源状態(決定ボタンで確定)
//-----------------------------------------------------------------------------
// 修正されたscreen2関数
//-----------------------------------------------------------------------------
void screen2() {
  cls();
  locateXY(0,0); putStr("Settings");
  
  // volume行
  locateXY(0,2);
  putStr(" "); // 初期状態では空白
  locateXY(2,2);
  putStr("volume: ");
  if (m_select == 0 && mode == 1) {
    putDec(temp_volume, 2);
  } else {
    putDec(m_volume, 2);
  }

  // power行
  locateXY(0,3);
  putStr(" "); // 初期状態では空白
  locateXY(2,3);
  putStr("power : ");
  if (m_select == 1 && mode == 1) {
    if (temp_powerIndex == 0) {
      putStr("ON");
    } else {
      putStr("OFF");
    }
  } else {
    if (powerIndex == 0) {
      putStr("ON");
    } else {
      putStr("OFF");
    }
  }
  
  // 画面切り替え用の表示
  locateXY(0,6);
  putStr("Press 1 for MP3 Player");
  
  // 操作説明
  locateXY(0,7);
  putStr("2/4:Select 6:Enter");
  
  // カーソル位置を設定
  updateCursor(2, 2, m_select); // 2行目から開始、2つの選択肢、現在の選択
}


//-----------------------------------------------------------------------------
// 設定画面での操作処理
void act_settings(I_StgSt input) {
  int sw = input.sw;
  int num = swToNum(sw);

  if (mode == 0) {
    // 選択モード(音量か、電源か)
    if (num == 2 || num == 4) {                    // SW2(上) または SW4(下)
      m_select = 1 - m_select;
    } else if (num == 6) {                         // SW6(決定)
      mode = 1;                                    // 決定ボタンが押され、各値設定モードに移行
    }
  } else {
    // 音量設定
    if (m_select == 0) {
      if (num == 2 && temp_volume < 9) {          // SW2(上)　上限9
        temp_volume = temp_volume + 1;
        up_volume();                             // 音量UP処理（実装されていれば呼び出す）
      }
      if (num == 4 && temp_volume > 1) {           // SW4(下)　下限1
        temp_volume = temp_volume - 1;
        down_volume();                           // 音量DOWN処理（実装されていれば呼び出す）
      }
      if (num == 6) {                              // SW6(決定)
        m_volume = temp_volume;
        mode = 0;
      }
    }
    // 電源設定
    else if (m_select == 1) {
      if (num == 2 || num == 4) {                  // SW2(上) または SW4(下)
        temp_powerIndex = 1 - temp_powerIndex;
      }
      if (num == 6) {                              // SW6(決定)
        powerIndex = temp_powerIndex;
        mode = 0;                                  // 決定ボタンが押され、選択モードに戻る
      }
    }
    else {
      if (num == 2 || num == 4) {                  // SW2(上) または SW4(下)
        temp_powerIndex = 1 - temp_powerIndex;
      }
      if (num == 6) {                              // SW6(決定)
        powerIndex = temp_powerIndex;
        if (powerIndex == 1) {
          cls();
          locateXY(0, 2);
          putStr("Shutting down...");
          sleep(1000);
          // power_off();                           // 実際の電源OFF処理があれば呼び出す
        }
        mode = 0;
      }
    }
  }
}



