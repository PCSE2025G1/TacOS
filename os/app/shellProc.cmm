  putCh(chr(0x81));  // シャッフル 🔀
  locateXY(3, 6);
  putCh(chr(0x82));  // ループ 🔁
  locateXY(4, 6);
  putCh(chr(0x83));  // リピート
  locateXY(5, 6);
  putCh(chr(0x84));  // 次へ
  locateXY(6, 6);
  putCh(chr(0x85));  // 前へ
  locateXY(7, 6);
  putCh(chr(0x86));  // お気に入り ❤️


}

//-----------------------------------------------------------------------------
// 画面1
//-----------------------------------------------------------------------------
void screen1() {
  dbgPutStr("demoScreen1\n"); // デバッグ出力
  cls();                                            // LCDをクリアする
  dbgPutStr("Cleared LCD\n"); // デバッグ出力
  locateXY(0,0);
  putStr("MP3 Player demo");
  for (int i=1; i<=5; i=i+1) {                      // スイッチ1〜5に付いて
    locateXY(2,i+1);
    putCh(chr(ord('0')+i));                         // スイッチの番号
    putStr(":");
    char[] fname = mp3FilesGetName(i);              // 対応するファイル名
    if (fname!=null) putStr(fname);
  }
  locateXY(2,7);
  putStr("6:stop");                                 // 6番のスイッチ

    // 画面切り替え用の表示
  locateXY(0,8);
  putStr("Press 1 for Settings");
}

void asta(int y) {
  screen1();
  locateXY(0, y+1);
  putCh('*');
}




//================================================================================
// 2: 再生処理
// ===============================================================================
//-----------------------------------------------------------------------------
// 再生管理関数
//-----------------------------------------------------------------------------
// 再生モード定義
#define MODE_NORMAL  0    // 通常再生
#define MODE_LOOP    1    // ループ（全曲順次再生後、最初に戻る）
#define MODE_REPEAT  2    // リピート（同じ曲を繰り返し）
#define MODE_SHUFFLE 3    // シャッフル（ランダム順序で全曲再生）


void act_stream(I_StrmSt strm_in) {
    int num = swToNum(strm_in.sw);  // 構造体からスイッチ番号を取得

     // モード切り替え（3番ボタン）
    if (num == 3) {
        int newMode = (currentPlayMode + 1) % 4;
        
        // 各モードの処理を実行
        if (newMode == MODE_NORMAL) {
            normal();
        } else if (newMode == MODE_LOOP) {
            loop();
        } else if (newMode == MODE_REPEAT) {
            repeat();
        } else if (newMode == MODE_SHUFFLE) {
            shuffle();
        }
        
        screen2();
        return;
    }

    // 再生/停止切り替え（5番ボタン）
    if (num == 5) {
        if (playstatus == 1) {
          isPaused = !isPaused; // 一時停止状態を切り替え
            // if (isPaused) {
            //     mp3pause();
            // } else {
            //     mp3resume();
            // }

        //     stop(true); // 再生停止
        // } else {
        //     play(mp3FilesGetPath(idx+1)); // 再生開始
        // }
        screen2();
        return;
        }
    }

  // リピートモードでは次/前の曲移動のみ無効化（再生制御は有効）
    // if (currentPlayMode == MODE_REPEAT && (num == 4 || num == 6)) {
    //     return; // 次/前の曲移動のみブロック
    // }

    // 次の曲（6番ボタン）
    if (num == 6) {
        next();
        screen2();
        return;
    }

    // 前の曲（4番ボタン）
    if (num == 4) {
        previous();
        screen2();
        return;
    }
}



//================================================================================
// 3: 設定処理
// ================================================================================
//-----------------------------------------------------------------------------
// グローバル変数：状態を保持
//-----------------------------------------------------------------------------
// int sel_mode = 0;            // 動作状態(0:選択中, 1:設定中)
int sel_line = 0;        // 設定状態(0:音量, 1:電源, 2:スピード)
int vol = 5;        // 音量(0~10)
int temp_vol = 5;     // 選択中の音量(決定ボタンで確定)
int pwr = 0;      // 電源状態(0:ON, 1:OFF)
int temp_pwr = 0; // 選択中の電源状態(決定ボタンで確定)

int speed_mode = 1;     // スピード(0:0.5x, 1:1.0x, 2:2.0x)
int temp_speed = 1;
//-----------------------------------------------------------------------------
// 設定画面での操作処理　→　音量調整中は再生を停止し、調整後に再び流れ始める
//-----------------------------------------------------------------------------
void act_settings(I_StgSt stg_in) {

  int num = swToNum(stg_in.sw);  // 構造体からスイッチ番号に変換

  if (sel_mode == 0) {
    // 選択モード（音量/電源/スピード）
    if (num == 2 && sel_line > 0) {
      sel_line = sel_line - 1;  // 上へ（上限0）
    } else if (num == 4 && sel_line < 2) {
      sel_line = sel_line + 1;  // 下へ（下限2）
    } else if (num == 6) {
      isPaused = true;
      sel_mode = 1;
    }
  // if (sel_mode == 0) {
  //   // 選択モード(音量か、電源か)
  //   if (num == 2 || num == 4) {                    // SW2(上) または SW4(下)
  //     sel_line = 1 - sel_line;
  //   } else if (num == 6) {                         // SW6(決定)
  //     // stop(true); // 再生停止
  //     isPaused = true;
  //     sel_mode = 1;                                    // 決定ボタンが押され、各値設定モードに移行
  //   }
  // 設定モード
  } else {
    // 音量設定
    if (sel_line == 0) {
      // 音量値選択
      if (num == 2 && temp_vol < 10) {          // SW2(上)　上限10
        temp_vol = temp_vol + 1;
      }
      if (num == 4 && temp_vol > 1) {           // SW4(下)　下限1
        temp_vol = temp_vol - 1;
      }
      // 音量値設定
      if (num == 6) {                              // SW6(決定)
        vol = temp_vol;
        set_volume_level(vol);     // ← ここで音量を反映
        isPaused = false; // 再生を再開
        // play(mp3FilesGetPath(idx+1)); // 再生開始
        sel_mode = 0;                               // 決定ボタンが押され、選択モードに戻る
      }
    }
    // 電源設定
    else if (sel_line == 1) {
      if (num == 2 || num == 4) {                  // SW2(上) または SW4(下)
        temp_pwr = 1 - temp_pwr;
      }
      // 電源状態設定
      if (num == 6) {                              // SW6(決定)
        pwr = temp_pwr;
        sel_mode = 0;                                  // 決定ボタンが押され、選択モードに戻る
        // 電源OFFならオフ画面に
        if (pwr == 1) {     
          stop(false);     
          cls();
          locateXY(0, 2);
          putStr("Shutting down...");
          sleep(1000);
          power_off(); // 電源OFF処理があれば呼び出す  
          
          // -- 復帰後 ----
          set_volume_level(vol);   // 音量レベル再設定
          pwr = 0; // 電源状態をリセット
        }
        isPaused = false; // 再生を再開
      }
    }else if (sel_line == 2) {
      // スピード設定
      if (num == 2 && temp_speed < 2) temp_speed = temp_speed + 1; // 上限2
      if (num == 4 && temp_speed > 0) temp_speed = temp_speed - 1;
      if (num == 6) {
        speed_mode = temp_speed;
        set_speed(speed_mode);  // 再生スピード反映
        // set_speed();  // 再生スピード反映
        play(mp3FilesGetPath(idx+1)); // 再生開始
        isPaused = false;
        sel_mode = 0;
      }
    }
  }
}
//-----------------------------------------------------------------------------
// screen3関数：画面表示
//-----------------------------------------------------------------------------
void screen3() {
  cls();
  locateXY(0,0); putStr("Settings");
  
  // volume行----------------------
  locateXY(0,2);
  putStr(" "); // 初期状態では空白
  locateXY(2,2);
  putStr("volume: ");

  int disp_level;
  if (sel_line == 0 && sel_mode == 1) {
      disp_level = temp_vol;       // 調整中の音量
  } else {
      disp_level = vol;   // 現在の音量
  }

  putDec(disp_level, 2);  // 「1〜10」の値を表示
  putStr("/10");          // 最大値の表示


  // power行--------------------------
  locateXY(0,3);
  putStr(" "); // 初期状態では空白
  locateXY(2,3);
  putStr("power : ");
  if (sel_line == 1 && sel_mode == 1) {
    if (temp_pwr == 0) {
      putStr("ON");
    } else {
      putStr("OFF");
    }
  } else {
    if (pwr == 0) {
      putStr("ON");
    } else {
      putStr("OFF");
    }
  }
   // ----------- speed行 -------------
  locateXY(0,4); putStr(" ");
  locateXY(2,4); putStr("speed : ");
  int disp_speed;
  if(sel_line == 2 && sel_mode == 1) {
    if(temp_speed == 0) {
      disp_speed = 0; // 0.5x
    } else if(temp_speed == 1) {
      disp_speed = 1; // 1.0x
    } else {
      disp_speed = 2; // 2.0x 
    }
  } else {
    disp_speed = speed_mode; // 現在のスピード
  }

  if (disp_speed == 0) {
    putStr("0.5x");
  } else if (disp_speed == 1) {
    putStr("1.0x");
  } else {
    putStr("2.0x");
  }

  // ----　各イラスト表示 -----------------------------
  // ------- 音量バーの表示 (音量メニュー選択中)---------------------------
  if (sel_line == 0) {
    locateXY(1,6);
    putCh(chr(0x87)); // メガホン
    locateXY(2,6);
    putCh(chr(0x88));  // Wi-Fi
    locateXY(4,6); 

    int vol_bar;
    if (sel_mode == 1) {    // 決定ボタンが押された状態
        vol_bar = temp_vol;  // 音量調整中の一時値
    } else {
        vol_bar = vol;  // 通常時の音量
    }
    // バーの表示
    for (int i = 1; i <= 10; i = i + 1) {
        if (i <= vol_bar) {
            putCh(chr(0x89));  // 音量あり部分
        } else {
            putCh(chr(0x8a));  // 空き部分
        }
    }
  }
  // ------- 電源の表示 (電源メニュー選択中)---------------------------
  else if (sel_line == 1) {
    locateXY(3,6);
    putCh(chr(0x8b)); // 電源on　左
    putCh(chr(0x8c)); // 　　　　右
    locateXY(6,6);
    putCh(chr(0x8d)); // 電源off左
    putCh(chr(0x8e)); // 　　　　右

    int disp_pwr;
    if (sel_mode == 1) {  // 決定ボタンが押された状態
      disp_pwr = temp_pwr; // 選択中の電源状態
    }
    else disp_pwr = pwr; // 現在の電源状態

    if (disp_pwr == 0) {   // 電源ONに上矢印
      locateXY(7,7);
      putCh(chr(0x8f));
    } else {               // 電源OFFに上矢印
      locateXY(4,7);
      putCh(chr(0x8f));
    }
  }
  else if (sel_line == 2 ){
    locateXY(3,6);
    putCh(chr(0x90)); // かめ　左
    putCh(chr(0x91)); // 　　　　右
    locateXY(7,6);
    putCh(chr(0x92)); // 人
    locateXY(10,6);
    putCh(chr(0x93)); // うさぎ　左
    putCh(chr(0x94)); // 　　　　右

    int disp_spd;
    if (sel_mode == 1) {  // 決定ボタンが押された状態
      disp_spd = temp_speed; // 選択中のスピード状態
    }
    else disp_spd = speed_mode; // 現在のスピード状態

    if (disp_spd == 0) {   // 0.5x
      locateXY(5,6);
      putCh(chr(0x95));
    } else if (disp_spd == 1) {   // 1.0x
      locateXY(8,6);
      putCh(chr(0x95));
    } else {   // 2.0x
      locateXY(12,6);
      putCh(chr(0x95));
    }
  }


  // カーソル位置を設定
  updateCursor(2, 2, sel_line); // 2行目から開始、2つの選択肢、現在の選択
}


