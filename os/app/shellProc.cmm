//-----------------------------------------------------------------------------
// 画面管理
//-----------------------------------------------------------------------------
int currentScreen = 0;                              // 現在の画面 (0:home, 1:screen1, 2:screen2, 3:screen3)
int homeSelection = 0;                              // ホーム画面での選択項目 (0:screen1, 1:screen2, 2:screen3)

//-----------------------------------------------------------------------------
// 共通のカーソル表示関数
//-----------------------------------------------------------------------------
// 指定した範囲の行のカーソルを更新する
// startRow: カーソル表示開始行
// itemCount: 選択肢の数
// selectedIndex: 現在選択されている項目のインデックス（0から開始）
void updateCursor(int startRow, int itemCount, int selectedIndex) {
  // 全ての行のカーソルをクリア
  for (int i = 0; i < itemCount; i = i + 1) {
    locateXY(0, startRow + i);
    putStr(" ");
  }
  
  // 現在の選択位置にカーソルを表示
  locateXY(0, startRow + selectedIndex);
  putStr(">");
}


//-----------------------------------------------------------------------------
// 共通のナビゲーション処理関数
//-----------------------------------------------------------------------------
// 上下移動処理を行い、選択項目が変更されたかどうかを返す
// currentSelection: 現在の選択項目のポインタ
// maxItems: 最大選択項目数
// buttonNum: 押されたボタン番号
// 戻り値: 選択項目が変更された場合1、変更されなかった場合0
int handleNavigationValue(int currentSelection, int maxItems, int buttonNum) {
  if (buttonNum == 2 && currentSelection > 0) {
    return currentSelection - 1;
  } else if (buttonNum == 4 && currentSelection < maxItems - 1) {
    return currentSelection + 1;
  }
  return currentSelection;
}

//-----------------------------------------------------------------------------
// 修正されたhomeScreen関数
//-----------------------------------------------------------------------------
void homeScreen() {
  cls();
  locateXY(0, 0);
  putStr("Home");
  
  // 選択肢の表示（カーソルを付けずに表示）
  locateXY(0, 2);
  putStr(" Screen1");
  locateXY(0, 3);
  putStr(" Screen2");
  locateXY(0, 4);
  putStr(" Screen3");
  
  // 操作説明
  locateXY(0, 6);
  putStr("2/4:Select 6:Enter");
  
  // 初期カーソル位置を設定
  updateCursor(2, 3, homeSelection); // 2行目から開始、3つの選択肢、現在の選択
}

//-----------------------------------------------------------------------------
// 画面1
//-----------------------------------------------------------------------------
void screen1() {
  dbgPutStr("demoScreen1\n"); // デバッグ出力
  cls();                                            // LCDをクリアする
  dbgPutStr("Cleared LCD\n"); // デバッグ出力
  locateXY(0,0);
  putStr("MP3 Player demo");
  for (int i=1; i<=5; i=i+1) {                      // スイッチ1〜5に付いて
    locateXY(2,i+1);
    putCh(chr(ord('0')+i));                         // スイッチの番号
    putStr(":");
    char[] fname = mp3FilesGetName(i);              // 対応するファイル名
    if (fname!=null) putStr(fname);
  }
  locateXY(2,7);
  putStr("6:stop");                                 // 6番のスイッチ

    // 画面切り替え用の表示
  locateXY(0,8);
  putStr("Press 1 for Settings");
}

void asta(int y) {
  screen1();
  locateXY(0, y+1);
  putCh('*');
}


//-----------------------------------------------------------------------------
// 画面表示 2: 設定画面
//-----------------------------------------------------------------------------
//-----------------------------------------------------------------------------
// グローバル変数：状態を保持
//-----------------------------------------------------------------------------
int mode = 0;            // 動作状態(0:選択中, 1:設定中)
int m_select = 0;        // 設定状態(0:音量, 1:電源)
int m_volume = 1;        // 音量(0~10)
int temp_volume = 1;     // 選択中の音量(決定ボタンで確定)
int powerIndex = 0;      // 電源状態(0:ON, 1:OFF)
int temp_powerIndex = 0; // 選択中の電源状態(決定ボタンで確定)
//-----------------------------------------------------------------------------
// 修正されたscreen2関数
//-----------------------------------------------------------------------------
void screen2() {
  cls();
  locateXY(0,0); putStr("Settings");
  
  // volume行
  locateXY(0,2);
  putStr(" "); // 初期状態では空白
  locateXY(2,2);
  putStr("volume: ");
  if (m_select == 0 && mode == 1) {
    putDec(temp_volume, 2);
  } else {
    putDec(m_volume, 2);
  }

  // power行
  locateXY(0,3);
  putStr(" "); // 初期状態では空白
  locateXY(2,3);
  putStr("power : ");
  if (m_select == 1 && mode == 1) {
    if (temp_powerIndex == 0) {
      putStr("ON");
    } else {
      putStr("OFF");
    }
  } else {
    if (powerIndex == 0) {
      putStr("ON");
    } else {
      putStr("OFF");
    }
  }
  
  // 画面切り替え用の表示
  locateXY(0,6);
  putStr("Press 1 for MP3 Player");
  
  // 操作説明
  locateXY(0,7);
  putStr("2/4:Select 6:Enter");
  
  // カーソル位置を設定
  updateCursor(2, 2, m_select); // 2行目から開始、2つの選択肢、現在の選択
}


//-----------------------------------------------------------------------------
// 設定画面での操作処理
// void act_settings(I_StgSt input) {
//   int sw = input.sw;
//   int num = swToNum(sw);
void act_settings(int num) {

  if (mode == 0) {
    // 選択モード(音量か、電源か)
    if (num == 2 || num == 4) {                    // SW2(上) または SW4(下)
      m_select = 1 - m_select;
    } else if (num == 6) {                         // SW6(決定)
      mode = 1;                                    // 決定ボタンが押され、各値設定モードに移行
    }
  } else {
    // 音量設定
    if (m_select == 0) {
      if (num == 2 && temp_volume < 9) {          // SW2(上)　上限9
        temp_volume = temp_volume + 1;
        up_volume();                             // 音量UP処理（実装されていれば呼び出す）
      }
      if (num == 4 && temp_volume > 1) {           // SW4(下)　下限1
        temp_volume = temp_volume - 1;
        down_volume();                           // 音量DOWN処理（実装されていれば呼び出す）
      }
      if (num == 6) {                              // SW6(決定)
        m_volume = temp_volume;
        mode = 0;
      }
    }
    // 電源設定
    else if (m_select == 1) {
      if (num == 2 || num == 4) {                  // SW2(上) または SW4(下)
        temp_powerIndex = 1 - temp_powerIndex;
      }
      if (num == 6) {                              // SW6(決定)
        powerIndex = temp_powerIndex;
        mode = 0;                                  // 決定ボタンが押され、選択モードに戻る
      }
    }
    else {
      if (num == 2 || num == 4) {                  // SW2(上) または SW4(下)
        temp_powerIndex = 1 - temp_powerIndex;
      }
      if (num == 6) {                              // SW6(決定)
        powerIndex = temp_powerIndex;
        if (powerIndex == 1) {
          cls();
          locateXY(0, 2);
          putStr("Shutting down...");
          sleep(1000);
          // power_off();                           // 実際の電源OFF処理があれば呼び出す
        }
        mode = 0;
      }
    }
  }
}



//-----------------------------------------------------------------------------
// 再生モード定義
//-----------------------------------------------------------------------------
#define MODE_NORMAL  0    // 通常再生
#define MODE_LOOP    1    // ループ（全曲順次再生後、最初に戻る）
#define MODE_REPEAT  2    // リピート（同じ曲を繰り返し）
#define MODE_SHUFFLE 3    // シャッフル（ランダム順序で全曲再生）

//-----------------------------------------------------------------------------
// グローバル変数（改良版から統合）
//-----------------------------------------------------------------------------
int currentPlayMode = MODE_NORMAL;
int[] originalOrder;      // 元の曲順を保持
int[] shuffleOrder;       // シャッフル順序を保持
int shuffleIndex = 0;     // シャッフル再生での現在位置
int totalSongs = 0;       // 総曲数
boolean[] playedInShuffle; // シャッフルで再生済みかどうか
int shufflePlayedCount = 0; // シャッフルで再生済み曲数
boolean wasStoppedByUser = false;  // 自動 vs ユーザー操作の区別


int screen3Selection = 0;                          // Screen3での選択項目
// 再生オプションの状態
boolean is_loop_enabled = true;
boolean is_repeat_enabled = false;
boolean is_shuffle_enabled = false;
boolean is_normal_enabled = true; // 通常再生は常に有効
song currentSong;         // 現在再生中の曲（構造体）
int idx = 0;                                       // 再生中の曲のインデックス（0から始まる）
// int playstatus = 0;                             // 再生状態 (0:停止, 1:再生中)

//-----------------------------------------------------------------------------
// 改良版MP3プレーヤー初期化・管理関数
//-----------------------------------------------------------------------------
int getTotalSongs() {
    int count = 0;
    for (int i = 1; i <= 5; i = i + 1) {
        if (mp3FilesGetName(i) != null) {
            count = count + 1;
        }
    }
    return count;
}

void initPlaylist() {
    totalSongs = getTotalSongs();
    if (totalSongs == 0) return;
    
    originalOrder = malloc(sizeof(int) * totalSongs);
    shuffleOrder = malloc(sizeof(int) * totalSongs);
    playedInShuffle = malloc(sizeof(boolean) * totalSongs);
    
    int index = 0;
    for (int i = 1; i <= 5; i = i + 1) {
        if (mp3FilesGetName(i) != null) {
            originalOrder[index] = i;
            shuffleOrder[index] = i;
            playedInShuffle[index] = false;
            index = index + 1;
        }
    }
}

void generateShuffleOrder() {
    if (totalSongs <= 1) return;
    
    for (int i = 0; i < totalSongs; i = i + 1) {
        shuffleOrder[i] = originalOrder[i];
        playedInShuffle[i] = false;
    }
    
    // Fisher-Yates シャッフル
    for (int i = totalSongs - 1; i > 0; i = i - 1) {
        int j = rand() % (i + 1);
        int temp = shuffleOrder[i];
        shuffleOrder[i] = shuffleOrder[j];
        shuffleOrder[j] = temp;
    }
    
    shuffleIndex = 0;
    shufflePlayedCount = 0;
}

int getCurrentSongNumber() {
    if (currentPlayMode == MODE_SHUFFLE) {
        if (shuffleIndex >= 0 && shuffleIndex < totalSongs) {
            return shuffleOrder[shuffleIndex];
        }
    }
    return idx + 1;
}

int getSongIndex(int songNumber) {
    for (int i = 0; i < totalSongs; i = i + 1) {
        if (originalOrder[i] == songNumber) {
            return i;
        }
    }
    return 0;
}

void changePlayMode(int newMode) {
    int oldMode = currentPlayMode;
    currentPlayMode = newMode;
    int currentSong = getCurrentSongNumber();
    
    // switch文をif-else文に変更
    if (newMode == MODE_NORMAL) {
        idx = 0;
    } else if (newMode == MODE_LOOP) {
        idx = getSongIndex(currentSong);
    } else if (newMode == MODE_REPEAT) {
        idx = getSongIndex(currentSong);
    } else if (newMode == MODE_SHUFFLE) {
        generateShuffleOrder();
        for (int i = 0; i < totalSongs; i = i + 1) {
            if (shuffleOrder[i] == currentSong) {
                shuffleIndex = i;
                break;
            }
        }
        idx = getSongIndex(currentSong);
    }
    
    // 各フラグの設定
    is_normal_enabled = (newMode == MODE_NORMAL);
    is_loop_enabled = (newMode == MODE_LOOP);
    is_repeat_enabled = (newMode == MODE_REPEAT);
    is_shuffle_enabled = (newMode == MODE_SHUFFLE);
}

char[] getPlayModeString() {
    // switch文をif-else文に変更
    if (currentPlayMode == MODE_NORMAL) {
        return "Normal";
    } else if (currentPlayMode == MODE_LOOP) {
        return "Loop";
    } else if (currentPlayMode == MODE_REPEAT) {
        return "Repeat";
    } else if (currentPlayMode == MODE_SHUFFLE) {
        return "Shuffle";
    }
    return "Unknown";
}




//-----------------------------------------------------------------------------
// 改良版screen3()（既存関数を改良）
//-----------------------------------------------------------------------------
void screen3() {
    cls();
    // タイトル
    locateXY(0, 0);
    putStr("Play Mode");
    locateXY(10, 0); // 右側に曲番号を表示
    putDec(idx + 1, 1); // 現在の曲番号（1から始まる）
    putStr("/");
    putDec(getTotalSongs(), 1); // 総曲数
    
    // L/R/S モード表示(全部で16文字)
    locateXY(10, 1);
    if (is_loop_enabled) putStr("L");
    else putStr("-");
    putStr("/");
    if (is_repeat_enabled) putStr("R");
    else putStr("-");
    putStr("/");
    if (is_shuffle_enabled) putStr("S");
    else putStr("-");
    
    // ファイル名取得（idx + 1）を使って screen1 と一致
    // 変更後（シンプルな直接取得）
    int songNum = idx + 1; // mp3FilesGetName は 1 から始まる
    char[] fname = mp3FilesGetName(songNum); // char[] → char*
    if (fname != null) {
        locateXY(2, 3);
        putStr(fname);
    }
    
    // パス表示（あれば）
    char[] path = mp3FilesGetPath(idx + 1); // char[] → char*
    if (path != null) {
        locateXY(2, 4);
        putStr(path);
    } else {
        locateXY(2, 4);
        putStr("N/A");
    }
    
    // 再生状態
    locateXY(6, 5);
    if (playstatus == 1) {
        putStr("||");
        locateXY(6, 6);
        putStr("再生中");
    } else {
        putStr(">|");
        locateXY(6, 6);
        putStr("停止中");
    }
    
    // 前/次
    locateXY(2, 5);
    putStr("<");
    locateXY(10, 5);
    putStr(">");
    
    // 操作説明
    locateXY(0, 7);
    putStr("1:戻る 2/4:↑↓ 3:mode 4:next 5:決定 6:prev");
}


//-----------------------------------------------------------------------------
// 画面表示 3: サンプル画面（修正版）
//-----------------------------------------------------------------------------

void stopPlay() {
  wasStoppedByUser = true;  // ユーザーによる停止
  playstatus = 0;

  stop();
  // playstatus = 0;
  // 画面が現在Screen3の場合は画面を更新
  if (currentScreen == 3) {
    screen3();
  }
}

