void startPlay() {
  int songNum = idx + 1;
  char[] path = mp3FilesGetPath(songNum);
  if (path != null) {
    play(path);              // 再生要求
    playstatus = 1;
  }

  if (currentScreen == 3) {
    screen3();
  }
}



//-----------------------------------------------------------------------------
// 改良版次/前曲移動（既存関数を改良）
//-----------------------------------------------------------------------------
void nextSong() {
    if (totalSongs == 0) return;
    if (currentPlayMode == MODE_REPEAT) {
        return;
    }
    boolean wasPlaying = (playstatus == 1); // boolean → int
    if (wasPlaying) {
        stopPlay();
    }
    
    // switch文をif-else文に変更
    if (currentPlayMode == MODE_NORMAL) {
        idx = idx + 1;
        if (idx >= totalSongs) {
            idx = totalSongs - 1;
            return;
        }
    } else if (currentPlayMode == MODE_LOOP) {
        idx = (idx + 1) % totalSongs;
    } else if (currentPlayMode == MODE_SHUFFLE) {
        shuffleIndex = shuffleIndex + 1;
        if (shuffleIndex >= totalSongs) {
            generateShuffleOrder();
        }
        idx = getSongIndex(shuffleOrder[shuffleIndex]);
    }
    
    // if (wasPlaying) {
    //     startPlay();
    // }
    startPlay(); // 再生を開始
}

void previousSong() {
    if (totalSongs == 0) return;
    if (currentPlayMode == MODE_REPEAT) {
        return;
    }
    boolean wasPlaying = (playstatus == 1); // boolean → int
    if (wasPlaying) {
        stopPlay();
    }
    
    // switch文をif-else文に変更
    if (currentPlayMode == MODE_NORMAL) {
        idx = idx - 1;
        if (idx < 0) {
            idx = 0;
            return;
        }
    } else if (currentPlayMode == MODE_LOOP) {
        idx = (idx - 1 + totalSongs) % totalSongs;
    } else if (currentPlayMode == MODE_SHUFFLE) {
        shuffleIndex = shuffleIndex - 1;
        if (shuffleIndex < 0) {
            generateShuffleOrder();
            shuffleIndex = totalSongs - 1;
        }
        idx = getSongIndex(shuffleOrder[shuffleIndex]);
    }
    
    // if (wasPlaying) {
    //     startPlay();
    // }
    startPlay(); // 再生を開始
}


//-----------------------------------------------------------------------------
// 改良版act_streamMng()（既存関数を改良）
//-----------------------------------------------------------------------------
void act_streamMng(int num) {
    // モード切り替え（3番ボタン）
    if (num == 3) {
        int newMode = (currentPlayMode + 1) % 4;
        changePlayMode(newMode);
        screen3();
        return;
    }

    // 再生/停止切り替え（5番ボタン）
    if (num == 5) {
        if (playstatus == 1) {
            stopPlay();
        } else {
            startPlay();
        }
        screen3();
        return;
    }

  // リピートモードでは次/前の曲移動のみ無効化（再生制御は有効）
    if (currentPlayMode == MODE_REPEAT && (num == 4 || num == 6)) {
        return; // 次/前の曲移動のみブロック
    }

    // 次の曲（4番ボタン）
    if (num == 6) {
        nextSong();
        screen3();
        return;
    }

    // 前の曲（6番ボタン）
    if (num == 4) {
        previousSong();
        screen3();
        return;
    }
}

//-----------------------------------------------------------------------------
// 曲終了時の自動再生制御（新規追加）
//-----------------------------------------------------------------------------
void onSongEnd() {
    if (currentPlayMode == MODE_NORMAL) {
        if (idx + 1 < totalSongs) {
            nextSong();
        } else {
            stopPlay();
        }
    } else if (currentPlayMode == MODE_LOOP) {
        nextSong();
    } else if (currentPlayMode == MODE_REPEAT) {
        startPlay();
    } else if (currentPlayMode == MODE_SHUFFLE) {
        nextSong();
    }
}


//-----------------------------------------------------------------------------
// メインプロセス
//-----------------------------------------------------------------------------

public void shellMain() {
  spiResetLcd();                                    // sleepを使用するので
  spiResetMp3();                                    //   プロセスが実行する
  mp3FilesInit();                                   // ファイル一覧を作る

  dbgPutStr("Starting Application...\n");

  // 改良版プレーヤー初期化
  initPlaylist();
  currentPlayMode = MODE_NORMAL;
  idx = 0;
  playstatus = 0;
  is_normal_enabled = true;
  is_loop_enabled = false;
  is_repeat_enabled = false;
  is_shuffle_enabled = false;
  int prevStatus = 0; // ← ここを追加！

  // 初期画面を表示
  homeScreen();

  dbgPutStr("Home screen displayed\n");
  
  for (;;) {
    // prevStatus = playstatus;
    if (playstatus == -1 && !wasStoppedByUser) {
      onSongEnd();  // 自動再生処理（リピート・ループなど）
    }

    int sw = readSw();
    int num = swToNum(sw);

    // スイッチの値をデバッグ出力
    if (sw != 0) {
      if (num == 1) dbgPutStr("Switch 1 pressed\n");
      else if (num == 2) dbgPutStr("Switch 2 pressed\n");
      else if (num == 3) dbgPutStr("Switch 3 pressed\n");
      else if (num == 4) dbgPutStr("Switch 4 pressed\n");
      else if (num == 5) dbgPutStr("Switch 5 pressed\n");
      else if (num == 6) dbgPutStr("Switch 6 pressed\n");
      else dbgPutStr("Unknown switch pressed\n");
    }

    // SW1でホーム画面に戻る（ホーム画面以外から）
    if (num == 1 && currentScreen != 0) {
      currentScreen = 0;
      homeSelection = 0;                            // 選択をリセット
      homeScreen();
    }
    
// 【修正D】メインループ内のこの部分を変更
    // // 各画面での処理
    // else if (currentScreen == 0) {                  // ホーム画面
    //   if (num == 2) {                               // 上移動
    //     homeSelection = homeSelection - 1;
    //     if (homeSelection < 0) homeSelection = 2;
    //     homeScreen();                             // homeScreen()から変更
    //     // homeScreenCursor();                         // homeScreen()から変更
    //   } else if (num == 4) {                        // 下移動
    //     homeSelection = homeSelection + 1;
    //     if (homeSelection > 2) homeSelection = 0;
    //     homeScreen();                             // homeScreen()から変更
    //     // homeScreenCursor();                         // homeScreen()から変更
    //   }
    else if (currentScreen == 0) {                  // ホーム画面
      int newSelection = handleNavigationValue(homeSelection, 3, num);
      if (newSelection != homeSelection) {
        homeSelection = newSelection;
        homeScreen();                               // 選択が変更された場合は画面を更新
      } else if (num == 6) {                        // 決定
        currentScreen = homeSelection + 1;          // screen1=1, screen2=2, screen3=3
        if (currentScreen == 1) {
          screen1();
        } else if (currentScreen == 2) {
          screen2();
        } else if (currentScreen == 3) {
          screen3();
        }
      }
    // 【修正C】ここまで
    } else if (currentScreen == 1) {                // Screen1 (MP3プレーヤ)
      if (num == 6) {                               // 6 番のスイッチが押された
        dbgPutStr("stop\n");
        screen1();                                  // 画面を初期化
        stop_c();
      } else if (num > 1 && num <= 5 && mp3FilesGetName(num) != null) { // ファイルと対応するボタン
        idx = num - 1;  // 曲名取得のため、グローバル変数に保存
        screen1();                                  // 画面を初期化
        asta(num);                                  // 再生中の曲に印を表示
        // play(mp3FilesGetPath(num));                 // 再生開始

        // play_c(queue, idx);   // queueとidxを渡す
        // 変更後
        play(mp3FilesGetPath(num));                 // 再生開始
        playstatus = 1;                             // 再生状態を更新

        dbgPutStr(mp3FilesGetPath(num));
        dbgPutStr("\n");
      }

    } else if (currentScreen == 2) {                // Screen2 (設定)
      // I_StgSt input;
      // input.sw = sw;
      // act_settings(input);
      act_settings(num);  // int型でそのまま渡す
      screen2();                                    // 画面を更新
    } else if (currentScreen == 3) {                // Screen3
      // Screen3での独自処理があればここに追加
      // 現在は何もしない
      // act_screen3(num);                             // Screen3の操作処理
      act_streamMng(num);                           // Screen3の操作処理
    }
    
    sleep(10);                                      // 10ms に一度
  }
}


