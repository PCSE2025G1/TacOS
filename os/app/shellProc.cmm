  { '\x00','\x00','\x00','\x00','\x00','\x00','\x00','\x00' },  // (x,y) = (0,5)
  //2行目
  { '\x00','\x00','\x00','\x00','\x80','\xc0','\x40','\x7c' },  // (x,y) = (1,0)
  { '\xc7','\xc1','\x78','\x4e','\x83','\x01','\x00','\x00' },  // (x,y) = (1,1)
  { '\x00','\x80','\x80','\x80','\x80','\x80','\x80','\x80' },  // (x,y) = (1,2)
