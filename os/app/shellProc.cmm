// 再生オプションの状態
boolean is_loop_enabled = false;
boolean is_repeat_enabled = false;
boolean is_shuffle_enabled = false;
song currentSong;         // 現在再生中の曲（構造体）
int idx = 0;                                       // 再生中の曲のインデックス（0から始まる）
int playstatus = 0;                             // 再生状態 (0:停止, 1:再生中)


// 配列の長さを取得するヘルパー関数
int length(song[] arr) {
    if (arr == null) return 0;
    
    int count = 0;
    // song構造体のpathがnullまたはidが-1の場合を終端とする
    // while (arr[count].path != null && arr[count].id != -1) {
    while (arr[count].path != null && arr[count].index != -1) {
        count=count + 1; // 有効な曲がある限りカウント
    }
    return count;
}

public void setCurrentSong(song[] queue) {
  if (queue != null && idx >= 0 && idx < length(queue)) {
    currentSong = queue[idx];   // グローバル変数にコピー
  } else {
    currentSong.index = -1;     // 無効な曲
  }
}

void screen3() {
  cls();

  // タイトル
  locateXY(0, 0);
  putStr("再生モード");

  // L/R/S モード表示
  locateXY(14, 1);
  if (is_loop_enabled) putStr("L"); else putStr("-");
  putStr("/");
  if (is_repeat_enabled) putStr("R"); else putStr("-");
  putStr("/");
  if (is_shuffle_enabled) putStr("S"); else putStr("-");

  // ファイル名取得（idx + 1）を使って screen1 と一致
  // char[] fname = mp3FilesGetName(idx + 1);
  // if (fname != null) {
  //   locateXY(2, 3);
  //   putStr(fname);
  // } else {
  //   locateXY(2, 3);
  //   putStr("(no song)");
  // }

  // song s = get_song(queue);
  // if (s != null) {
  //   locateXY(2, 3);
  //   putStr(s.name);
  // }

  setCurrentSong(queue);

  if (currentSong.index != -1) {
    locateXY(2, 3);
    putStr(currentSong.name);
  }

    // パス表示（あれば）
  char[] path = mp3FilesGetPath(idx + 1);
  if (path != null) {
    locateXY(2, 4);
    putStr(path);
  } else {
    locateXY(2, 4);
    putStr("N/A");
  }

  // 再生状態
  locateXY(6, 5);
  if (playstatus == 1) {
    putStr("||");
    locateXY(6, 6);
    putStr("再生中");
  } else {
    putStr(">|");
    locateXY(6, 6);
    putStr("停止中");
  }

  // 前/次
  locateXY(2, 5); putStr("<");
  locateXY(10, 5); putStr(">");

  // 操作説明
  locateXY(0, 7);
  putStr("1:戻る 2/4:↑↓ 3/5:< > 6:切替");
}

int streamSelect = 0;  // 選択カーソル：0=再生/停止, 1=Repeat, 2=Loop, 3=Shuffle

void act_streamMng(int num) {
  // カーソル移動
  int newSel = handleNavigationValue(streamSelect, 4, num);
  if (newSel != streamSelect) {
    streamSelect = newSel;
    screen3();
    return;
  }

  // 曲の再生/制御など
  if (num == 6) { // 切り替え操作
    if (streamSelect == 0) {
      // 再生/停止トグル
      if (playstatus == 1) {
        stop_c();
      } else {
        play_c(queue, idx);
      }
    } else if (streamSelect == 1) {
      is_repeat_enabled = !is_repeat_enabled;
    } else if (streamSelect == 2) {
      is_loop_enabled = !is_loop_enabled;
    } else if (streamSelect == 3) {
      is_shuffle_enabled = !is_shuffle_enabled;
    }
    screen3(); // 状態更新を反映
  }

  // 曲送り／戻し
  if (num == 3) {
    previous(queue);
    screen3();
  } else if (num == 5) {
    next(queue);
    screen3();
  }
}




